{
  "_comment": "Example: minimal projection — only name, primary email, phone, and skill names",
  "fields": [
    {
      "path": "full_name",
      "type": "string",
      "required": true
    },
    {
      "path": "primary_email",
      "from": "emails[0]",
      "type": "string",
      "required": true
    },
    {
      "path": "phone",
      "from": "phones[0]",
      "type": "string",
      "normalize": "E164"
    },
    {
      "path": "skills",
      "from": "skills[].name",
      "type": "string[]",
      "normalize": "canonical"
    },
    {
      "path": "current_title",
      "from": "experience[0].title",
      "type": "string"
    },
    {
      "path": "current_company",
      "from": "experience[0].company",
      "type": "string"
    }
  ],
  "include_confidence": true,
  "include_provenance": false,
  "on_missing": "null"
}
